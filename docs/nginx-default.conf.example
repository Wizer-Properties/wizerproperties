# Example nginx config for production. Copy to src/nginx/conf/default.conf
# (create src/nginx/conf/ if needed). Required for Certbot ACME (/.well-known/acme-challenge/).

server {
    listen 80;
    server_name _;

    # Let's Encrypt ACME challenge (required for certonly --webroot)
    location /.well-known/acme-challenge/ {
        root /var/www/certbot;
    }

    # Proxy all other requests to Django
    location / {
        proxy_pass http://web:8000;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}

# Optional: HTTPS server (uncomment after obtaining certs with certbot).
# Certbot writes to /etc/letsencrypt/live/DOMAIN/; nginx mounts ./certbot/conf/ at /etc/nginx/ssl/
# so use /etc/nginx/ssl/live/wizerproperties.com/fullchain.pem and privkey.pem.
